generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  name        String?
  username    String?
  avatar      String?
  bio         String?

  dateOfBirth DateTime?
  gender      String?
  height      Float?
  heightUnit  String?
  weight      Float?
  weightUnit  String?
  activity    String?

  goals       Goal[]
  workouts    Workout[]
  meals       MealLog[]
  
  workoutReminders Boolean @default(true)
  weeklyReports    Boolean @default(true)
  tipsAndTricks    Boolean @default(false)
}

model Goal {
  id    String @id @default(uuid())
  name  String @unique
  users User[]
}

model Workout {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  duration  Int      // in minutes
  calories  Int
  completed Boolean  @default(true)
  date      DateTime @default(now())
}

model MealLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  calories  Int
  protein   Int?
  carbs     Int?
  fat       Int?
  date      DateTime @default(now())
}
